BOT_TOKEN=YOUR_BOT_TOKEN_HERE
REDIS_URL=redis://redis:6379/0

# Alochi platform PostgreSQL — bot now connects here instead of standalone school_bot_db
ALOCHI_DB_URL=postgresql+asyncpg://user:password@alochi-db-host:5432/alochi_db

# Optional group for logs/announcements
GROUP_CHAT_ID=YOUR_GROUP_CHAT_ID

# Comma-separated Telegram user IDs that should be superadmins
SUPERADMIN_IDS=YOUR_TELEGRAM_ID

# Mandatory channel users must subscribe to before using /start.
# Bot MUST be admin in this channel. Leave empty to disable the subscription gate.
REQUIRED_CHANNEL=@alochi_offline

# Hours to wait between sending a poll to the parent group and DM-ing
# the consolidated results digest to the teacher's private chat. The
# default of 24 matches the production rollout; set to a fractional
# value (e.g. 0.083 for 5 minutes) when testing the digest end-to-end
# without waiting a full day. Read once at module import; bot restart
# is required to pick up a change.
TEACHER_NOTIFY_DELAY_HOURS=24

# DEPRECATED — remove after migration is confirmed stable
# DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@postgres:5432/school_bot_db
# POSTGRES_USER=YOUR_DB_USER
# POSTGRES_PASSWORD=YOUR_DB_PASSWORD
# POSTGRES_DB=school_bot_db
